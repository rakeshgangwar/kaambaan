{
  "name": "@kaambaan/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply kaambaan-catalog --local",
    "db:migrate": "wrangler d1 migrations apply kaambaan-catalog --remote",
    "db:seed:local": "wrangler d1 execute kaambaan-catalog --local --file scripts/seed-dev.sql",
    "dev:setup": "pnpm db:migrate:local && pnpm db:seed:local"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@kaambaan/contract": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.18",
    "@cloudflare/workers-types": "^4.20260619.1",
    "@kaambaan/agent-sdk": "workspace:*",
    "wrangler": "^4.103.0"
  }
}
